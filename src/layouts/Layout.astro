---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  canonical?: string;
  robots?: string;
  schema?: object;
}

const {
  title,
  description,
  ogTitle,
  ogDescription,
  ogImage = '/AccelliTec_OG_1200x630.png',
  canonical,
  robots = 'index, follow',
  schema,
} = Astro.props;

const siteUrl = 'https://accellitec.com';
const canonicalUrl = canonical ? `${siteUrl}${canonical}` : `${siteUrl}${Astro.url.pathname}`;
const resolvedOgImage = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- Favicons -->
  <link rel="icon" type="image/x-icon" href="/AccelliTec_favicon.ico" />
  <link rel="icon" type="image/png" sizes="512x512" href="/AccelliTec_favicon_512x512.png" />
  <link rel="apple-touch-icon" href="/AccelliTec_apple_touch_icon.png" />

  <!-- Primary Meta Tags -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content={robots} />
  <link rel="canonical" href={canonicalUrl} />

  <!-- Open Graph / LinkedIn / Facebook -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:title" content={ogTitle ?? title} />
  <meta property="og:description" content={ogDescription ?? description} />
  <meta property="og:image" content={resolvedOgImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:site_name" content="AccelliTec" />
  <meta property="og:locale" content="en_IN" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={ogTitle ?? title} />
  <meta name="twitter:description" content={ogDescription ?? description} />
  <meta name="twitter:image" content={resolvedOgImage} />

  <!-- Structured Data (Schema.org) -->
  {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}

  <!-- Default Organisation Schema on every page -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "AccelliTec",
    "url": siteUrl,
    "logo": `${siteUrl}/AccelliTec_Logo_300x300.png`,
    "contactPoint": {
      "@type": "ContactPoint",
      "telephone": "+91-96673-79021",
      "contactType": "customer service",
      "availableLanguage": ["English", "Hindi"]
    },
    "sameAs": [
      "https://linkedin.com/in/anshul-goyal13"
    ]
  })} />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body>
  <div class="grid-bg"></div>
  <slot />

  <!-- WhatsApp Floating Button -->
  <a
    href="https://wa.me/919667379021?text=Hi%20AccelliTec%2C%20I%27d%20like%20to%20know%20more%20about%20your%20services."
    target="_blank"
    rel="noopener"
    class="wa-fab"
    aria-label="Chat on WhatsApp"
  >
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" width="28" height="28" fill="white">
      <path d="M16 0C7.164 0 0 7.163 0 16c0 2.824.738 5.476 2.027 7.782L0 32l8.418-2.007A15.93 15.93 0 0016 32c8.837 0 16-7.163 16-16S24.837 0 16 0zm0 29.333a13.27 13.27 0 01-6.784-1.858l-.486-.29-5.002 1.193 1.264-4.867-.317-.5A13.27 13.27 0 012.667 16C2.667 8.636 8.636 2.667 16 2.667S29.333 8.636 29.333 16 23.364 29.333 16 29.333zm7.27-9.878c-.398-.199-2.354-1.161-2.719-1.294-.365-.133-.631-.199-.897.199-.266.398-1.03 1.294-1.262 1.56-.232.265-.465.298-.863.1-.398-.2-1.68-.619-3.2-1.974-1.183-1.054-1.981-2.356-2.213-2.754-.232-.398-.025-.613.174-.811.179-.178.398-.465.597-.697.2-.232.266-.398.398-.664.133-.265.067-.497-.033-.696-.1-.2-.897-2.162-1.229-2.96-.324-.778-.653-.672-.897-.684l-.764-.013c-.266 0-.697.1-1.063.497-.365.398-1.394 1.362-1.394 3.322 0 1.96 1.427 3.854 1.626 4.12.2.265 2.808 4.287 6.803 6.013.951.41 1.693.655 2.271.839.954.304 1.823.261 2.51.158.765-.114 2.354-.962 2.687-1.891.332-.93.332-1.727.232-1.893-.099-.165-.365-.265-.763-.464z"/>
    </svg>
    <span class="wa-label">Chat with us</span>
  </a>

  <style>
    .wa-fab {
      position: fixed;
      bottom: 28px;
      right: 28px;
      z-index: 999;
      display: flex;
      align-items: center;
      gap: 10px;
      background: #25D366;
      color: white;
      text-decoration: none;
      padding: 13px 20px 13px 16px;
      border-radius: 100px;
      box-shadow: 0 4px 24px rgba(37,211,102,0.35);
      font-family: 'DM Sans', sans-serif;
      font-size: 0.88rem;
      font-weight: 500;
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .wa-fab:hover {
      transform: translateY(-3px);
      box-shadow: 0 8px 32px rgba(37,211,102,0.45);
    }
    .wa-label { white-space: nowrap; }
    @media (max-width: 600px) {
      .wa-fab { padding: 14px; bottom: 20px; right: 20px; }
      .wa-label { display: none; }
    }
  </style>

  <script>
    const reveals = document.querySelectorAll('.reveal');
    const obs = new IntersectionObserver(entries => {
      entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
    }, { threshold: 0.1 });
    reveals.forEach(el => obs.observe(el));
  </script>
</body>
</html>
