---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "AI/ML in 2026 — What It Really Is and How to Get Started",
  "description": "Live masterclass by AccelliTec. Learn what AI/ML actually is, how it's used in real enterprise products, and how to start your AI journey in 30 days.",
  "organizer": { "@type": "Organization", "name": "AccelliTec", "url": "https://accellitec.com" },
  "eventMode": "OnlineEventAttendanceMode",
  "offers": { "@type": "Offer", "price": "99", "priceCurrency": "INR", "availability": "https://schema.org/InStock" },
  "inLanguage": ["hi", "en"]
};
---

<Layout
  title="AI/ML Live Masterclass — ₹99 Only | AccelliTec"
  description="Live 90-minute AI/ML masterclass by AccelliTec. Learn what AI/ML really is, how enterprises use it, and how to get started — no jargon, no hype. Only ₹99."
  canonical="/webinar"
  schema={schema}
>
  <Nav />

  <section style="background:var(--bg);position:relative;z-index:1;">
    <div class="wrap">
      <p class="s-label reveal">Live Masterclass</p>
      <h1 class="s-title reveal">Start your AI/ML journey — ₹99 only</h1>
      <p class="s-sub reveal">AccelliTec's live masterclass gives you a genuine taste of how we teach — enterprise experience, no jargon, real strategy.</p>

      <div class="webinar-wrap reveal">
        <div class="wb-top">
          <div>
            <div class="wb-tag">🎙 Live Masterclass by AccelliTec</div>
            <h2 class="wb-title">AI/ML in 2026 — What It Really Is<br/>and How to Get Started</h2>
            <ul class="wb-points">
              <li>What AI/ML actually is — no jargon, no hype, just clarity</li>
              <li>How AI/ML is used in real enterprise products today</li>
              <li>The 3 paths into AI/ML — developer, business owner, career switcher</li>
              <li>Top tools and technologies to start with right now</li>
              <li>How to go from zero to your first AI/ML project in 30 days</li>
            </ul>
            <a
              href="https://www.instamojo.com/@accellitek/l3fbdda6cfb824ff4b1712764ca21c9c0/"
              rel="im-checkout"
              data-text="Register Now — ₹99"
              data-css-style="color:#04080F; background:#00C8FF; width:100%; border-radius:8px; font-family:Syne,sans-serif; font-weight:700; font-size:15px; letter-spacing:0.02em;"
              data-layout="vertical"
            ></a>
          </div>
          <div class="wb-card">
            <div class="wb-free">₹99</div>
            <div class="wb-free-sub">Only ₹99. Save your spot.</div>
            <span class="wb-date-badge">📅 Date shared after registration</span>
            <a
              href="https://www.instamojo.com/@accellitek/l3fbdda6cfb824ff4b1712764ca21c9c0/"
              rel="im-checkout"
              data-text="Save My Spot — ₹99"
              data-css-style="color:#04080F; background:#00C8FF; width:100%; border-radius:8px; font-family:Syne,sans-serif; font-weight:700; font-size:14px;"
              data-layout="vertical"
            ></a>
            <div class="wb-seats">Only <strong>100 seats</strong> available</div>
          </div>
        </div>
        <div class="wb-bottom">
          <div class="wb-stat"><span class="wb-stat-val">100</span><span class="wb-stat-label">Seats Available</span></div>
          <div class="wb-stat"><span class="wb-stat-val">90</span><span class="wb-stat-label">Minutes Runtime</span></div>
          <div class="wb-stat"><span class="wb-stat-val">Live</span><span class="wb-stat-label">Q&A Included</span></div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<script src="https://js.instamojo.com/v1/button.js"></script>

<style>
  .webinar-wrap { margin-top:60px;border:1px solid var(--border);border-radius:20px;overflow:hidden; }
  .wb-top { display:grid;grid-template-columns:1fr auto;gap:48px;align-items:center;padding:56px;background:var(--surface);border-bottom:1px solid var(--border);position:relative;overflow:hidden; }
  .wb-top::after { content:'';position:absolute;top:-100px;right:-100px;width:400px;height:400px;border-radius:50%;background:radial-gradient(circle,rgba(0,200,255,0.06) 0%,transparent 70%);pointer-events:none; }
  .wb-tag { display:inline-block;font-family:'JetBrains Mono',monospace;font-size:0.68rem;letter-spacing:0.12em;color:var(--gold);text-transform:uppercase;background:var(--gold-dim);border:1px solid rgba(245,200,66,0.2);padding:4px 14px;border-radius:100px;margin-bottom:20px; }
  .wb-title { font-family:'Syne',sans-serif;font-size:1.5rem;font-weight:800;line-height:1.2;margin-bottom:18px; }
  .wb-points { list-style:none;display:flex;flex-direction:column;gap:10px;margin-bottom:32px; }
  .wb-points li { font-size:0.9rem;color:var(--muted2);display:flex;gap:10px;align-items:center; }
  .wb-points li::before { content:'✓';color:var(--cyan);font-weight:700;flex-shrink:0; }
  .wb-card { background:var(--bg);border:1px solid var(--border);border-radius:14px;padding:32px;text-align:center;min-width:220px;flex-shrink:0; }
  .wb-free { font-family:'Syne',sans-serif;font-size:3rem;font-weight:800;color:var(--gold);line-height:1; }
  .wb-free-sub { font-size:0.78rem;color:var(--muted);margin-bottom:20px; }
  .wb-date-badge { font-family:'JetBrains Mono',monospace;font-size:0.68rem;color:var(--muted2);background:var(--surface2);border:1px solid var(--border);padding:8px 14px;border-radius:6px;display:block;margin-bottom:18px;letter-spacing:0.06em; }
  .wb-seats { font-size:0.78rem;color:var(--muted);margin-top:12px; }
  .wb-seats strong { color:var(--gold); }
  .wb-bottom { display:grid;grid-template-columns:repeat(3,1fr);gap:0;background:var(--border); }
  .wb-stat { background:var(--surface);padding:28px 32px;text-align:center;border-right:1px solid var(--border); }
  .wb-stat:last-child { border-right:none; }
  .wb-stat-val { font-family:'Syne',sans-serif;font-size:2rem;font-weight:800;color:var(--cyan);display:block; }
  .wb-stat-label { font-size:0.78rem;color:var(--muted);margin-top:4px;font-family:'JetBrains Mono',monospace;letter-spacing:0.07em; }
  @media(max-width:960px){ .wb-top{grid-template-columns:1fr;padding:36px 28px;} .wb-bottom{grid-template-columns:1fr 1fr;} }
</style>
